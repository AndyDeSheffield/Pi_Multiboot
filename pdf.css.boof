@page {
    size: A4;
    margin: 5mm;
}
body {
    font-family: Arial, sans-serif;
    font-size: 10pt;
    line-height: 1.5;
    margin: 5mm;
}

h1, h2, h3, h4, h5 {
    font-family: Arial, sans-serif;
	font-size: 12pt;
    margin-top: 14pt;
    margin-bottom: 6pt;
}

pre, code {
    font-family: Consolas, monospace;
    font-size: 9pt;
}
